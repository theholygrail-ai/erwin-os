# =============================================================================
# Erwin OS - Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM (Groq) ---
# ROTATE YOUR KEY: The original key was exposed in chat.
# Generate a new key at https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_WITH_NEW_KEY
GROQ_MODEL=openai/gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ERWIN_OS_STACK_NAME=erwin-os
S3_ARTIFACTS_BUCKET=erwin-os-artifacts
SQS_JOB_QUEUE_URL=
SQS_DLQ_URL=
DYNAMODB_JOBS_TABLE=erwin-os-jobs
DYNAMODB_RUNS_TABLE=erwin-os-runs
DYNAMODB_ARTIFACTS_TABLE=erwin-os-artifacts
DYNAMODB_CONNECTORS_TABLE=erwin-os-connectors

# --- ClickUp ---
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_WEBHOOK_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:3001/connectors/clickup/oauth/callback
CLICKUP_TEAM_ID=

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-REPLACE
SLACK_APP_TOKEN=xapp-REPLACE
SLACK_SIGNING_SECRET=

# --- Google (Gmail + Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/connectors/google/oauth/callback
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/erwin-os-gmail
GOOGLE_PUBSUB_SUBSCRIPTION=projects/YOUR_PROJECT/subscriptions/erwin-os-gmail-sub

# --- WhatsApp Cloud API ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_NUMBER=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Nova Act (Primary Browser Automation) ---
NOVA_ACT_API_KEY=
NOVA_ACT_DAILY_BUDGET=10.00

# --- Server ---
API_PORT=7001
API_HOST=0.0.0.0
NODE_ENV=development

# --- Erwin Identity (for task classification) ---
ERWIN_CLICKUP_USER_ID=
ERWIN_EMAIL=erwin.mothoa@ecomplete.co.za
ERWIN_SLACK_USER_ID=
ERWIN_DISPLAY_NAME=Erwin Mothoa
